{
	"name": "manciple",
	"version": "0.4.5",
	"description": "A repo-native workflow layer for existing coding agents.",
	"license": "MIT",
	"author": "Daniel Patton",
	"homepage": "https://github.com/dpatton1992/manciple#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dpatton1992/manciple.git"
	},
	"bugs": {
		"url": "https://github.com/dpatton1992/manciple/issues"
	},
	"preferGlobal": true,
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"files": [
		"bin/",
		"dist/",
		"docs/",
		"README.md",
		"scripts/manciple-token-audit.mjs",
		".codex/skills/",
		".claude/skills/",
		".opencode/agents/"
	],
	"keywords": [
		"manciple",
		"ai",
		"agents",
		"coding-agents",
		"llm",
		"workflow",
		"prompt-engineering",
		"task-management",
		"cli"
	],
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"manciple": "bin/manciple.js",
		"manciple-mcp": "bin/manciple-mcp.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/cli.ts",
		"release": "tsx scripts/release.ts",
		"format:yaml": "tsx scripts/formatMancipleYaml.ts",
		"check:manciple-yaml": "tsx scripts/formatMancipleYaml.ts --check",
		"check:manciple-lifecycle": "tsx scripts/checkMancipleLifecycle.ts",
		"test": "NO_COLOR=1 tsx scripts/runVitest.ts --silent",
		"test:verbose": "NO_COLOR=1 tsx scripts/runVitest.ts",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm run check:manciple-yaml && pnpm run build && pnpm run test"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"commander": "^12.1.0",
		"fs-extra": "^11.2.0",
		"picocolors": "^1.1.1",
		"yaml": "^2.7.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.6"
	}
}
