{
  "name": "@dpatton1992/assignr",
  "version": "0.1.0",
  "description": "A repo-native workflow layer for existing coding agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "keywords": [
    "assignr",
    "ai",
    "agents",
    "coding-agents",
    "llm",
    "workflow",
    "prompt-engineering",
    "task-management",
    "cli"
  ],
  "bin": {
    "assignr": "./bin/assignr.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
